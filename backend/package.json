{
  "name": "quintern-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "cross-env NODE_ENV=production node src/app.js",
